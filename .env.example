# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Flask
FLASK_SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=true

# Database
DATABASE_URL=sqlite:///herlens.db

# Cryptographic timestamp signing key (keep secret; changing it invalidates old signatures)
TIMESTAMP_SECRET=change-me-to-a-long-random-string

# Public base URL used in PDF reports and verification links
APP_BASE_URL=http://127.0.0.1:5000

# Email (Gmail SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password

# Set to true to log emails instead of sending them
TESTING_MODE=true

# Security
ENABLE_DEBUG_ROUTES=false
MAX_UPLOAD_MB=16
# Optional: allow /history and /stats from non-local hosts with ?access_key=YOUR_KEY
ADMIN_ACCESS_KEY=
